# Neon Postgres (pooled connection string from the Neon console)
DATABASE_URL=

# Anthropic — used by pipeline/classify_brands.py (Batches API)
ANTHROPIC_API_KEY=

# Texas Comptroller SIFT (data-secure.comptroller.texas.gov) — only needed for
# the optional scripted download (pipeline/sift_fetch.py). The primary path is
# downloading the quarterly files by hand into data/downloads/sift/.
SIFT_USERNAME=
SIFT_PASSWORD=

# Optional: data.texas.gov app token (avoids Socrata throttling; works without)
SOCRATA_APP_TOKEN=
